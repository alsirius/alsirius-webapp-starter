{
  "name": "alsirius-webapp-starter",
  "version": "1.0.0",
  "description": "Complete, production-ready web application starter kit with authentication, user management, and all essential features built-in",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:packages": "npm run build:core && npm run build:react",
    "build:core": "tsc",
    "build:react": "cd packages/react && npm run build",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "setup": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "prepare": "npm run build:packages"
  },
  "keywords": [
    "webapp",
    "starter",
    "boilerplate",
    "authentication",
    "authorization",
    "jwt",
    "user-management",
    "invitations",
    "express",
    "react",
    "nextjs",
    "typescript",
    "fullstack",
    "saas",
    "template"
  ],
  "author": "Alsirius",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alsirius/alsirius-webapp-starter.git"
  },
  "bugs": {
    "url": "https://github.com/alsirius/alsirius-webapp-starter/issues"
  },
  "homepage": "https://github.com/alsirius/alsirius-webapp-starter#readme",
  "dependencies": {
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "nodemailer": "^6.9.7",
    "better-sqlite3": "^8.7.0",
    "joi": "^17.11.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^6.4.14",
    "@types/better-sqlite3": "^7.6.8",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
